# Supabase – Werte im Supabase Dashboard unter Project Settings > API finden
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=DEIN_SERVICE_ROLE_KEY

# OpenAI – https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Cloudflare R2 – S3-compatible API und öffentlicher Bucket (Development URL oder Custom Domain)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=meme-tagebuch

# Basis-URL ohne nachgestelltes Slash – z.B. https://pub-a1b2c3d4e5f67890.r2.dev
NEXT_PUBLIC_R2_PUBLIC_BASE=
